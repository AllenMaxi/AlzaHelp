# Required
MONGO_URL=mongodb://localhost:27017
DB_NAME=memorykeeper
JWT_SECRET_KEY=change-this-to-a-random-64-char-string
REQUIRE_JWT_SECRET=true
ENFORCE_HTTPS=true
COOKIE_SECURE=true
OPENAI_API_KEY=sk-...
CORS_ORIGINS=http://localhost:3000

# Baseline abuse protection
WRITE_RATE_LIMIT_ENABLED=true
WRITE_RATE_LIMIT_WINDOW_SECONDS=60
WRITE_RATE_LIMIT_MAX_REQUESTS=120

# Voice medication confirmation
VOICE_CONFIRMATION_TTL_SECONDS=600

# AI Models (optional, defaults shown)
EMBEDDING_MODEL=text-embedding-3-small
STT_MODEL=gpt-4o-mini-transcribe

# Stripe Billing (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_WEBHOOK_SECRET=

# Push Notifications (optional)
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=admin@alzahelp.com

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Navigation / Geocoding (optional)
NAV_HTTP_USER_AGENT=AlzaHelp/1.0 (care companion)
NAV_GEOCODING_PROVIDER=nominatim
NAV_GEOCODING_SEARCH_URL=https://nominatim.openstreetmap.org/search
NAV_ROUTING_PROVIDER=osrm
NAV_ROUTING_BASE_URL=https://router.project-osrm.org/route/v1
NAV_LOCATION_STALE_SAMPLE_SECONDS=180
NAV_NOMINATIM_MIN_INTERVAL_SECONDS=1.0

# Admin (optional)
ADMIN_BOOTSTRAP_EMAILS=

# ── Notification delivery engine ──
NOTIFICATION_MAX_ATTEMPTS=5
NOTIFICATION_BACKOFF_BASE_SECONDS=30
NOTIFICATION_BACKOFF_MAX_SECONDS=1800

# ── WhatsApp alert templates (Twilio Content SIDs) ──
TWILIO_WHATSAPP_FROM=
TWILIO_WA_TEMPLATE_SOS=
TWILIO_WA_TEMPLATE_FALL=
TWILIO_WA_TEMPLATE_GEOFENCE=
TWILIO_WA_TEMPLATE_MISSED_MED=
